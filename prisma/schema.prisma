generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                @id @default(uuid())
  login                     String                @unique
  passwordHash              String
  balance                   Float                 @default(0)
  referralBalance           Float                 @default(0)
  isBanned                  Boolean               @default(false)
  isAdmin                   Boolean               @default(false)
  hideAiMenu                Boolean               @default(false)
  referralCode              String                @unique
  referredById              String?
  joinedAt                  DateTime              @default(now())
  pendingDiscountFixed      Float                 @default(0)
  pendingDiscountPct        Float                 @default(0)
  botLoginCode              String?
  botLoginCodeExpiresAt     DateTime?
  telegramId                BigInt?               @unique
  telegramLinkCode          String?               @unique
  telegramLinkCodeExpiresAt DateTime?
  referralRate              Float                 @default(0.05)
  botState                  String?
  tempReferrerId            String?
  aiFreeTokensUsed          Int                   @default(0)
  aiPurchasedTokens         Int                   @default(0)
  ai_conversations          ai_conversations[]
  ai_files                  ai_files[]
  ai_subscriptions          ai_subscriptions?
  ai_usage_entries          ai_usage_entries[]
  devices                   Device[]
  finance_withdrawals       finance_withdrawals[]
  payments                  Payment[]
  paymentMethods            PaymentMethod[]
  promoActivations          PromoActivation[]
  subscription              Subscription?
  supportTickets            SupportTicket[]
  telegram_mailings         telegram_mailings[]
  transactions              Transaction[]
  referredBy                User?                 @relation("Referrals", fields: [referredById], references: [id])
  referrals                 User[]                @relation("Referrals")
  vpnTokens                 VpnToken[]
  withdrawals               Withdrawal[]

  @@map("users")
}

model SubscriptionPlan {
  id           String              @id @default(uuid())
  slug         String              @unique
  name         String
  features     String[]
  isPopular    Boolean             @default(false)
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)
  promoActive  Boolean             @default(false)
  promoPrice   Float?
  promoLabel   String?
  promoMaxUses Int?
  promoUsed    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  prices       SubscriptionPrice[]

  @@map("subscription_plans")
}

model SubscriptionPrice {
  id     String           @id @default(uuid())
  planId String
  period String
  price  Float
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, period])
  @@map("subscription_prices")
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique
  planId      String
  planName    String
  activeUntil DateTime
  isLifetime  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  autoRenewal Boolean  @default(true)
  billingPeriod String @default("monthly")
  autoRenewPaymentMethodId String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Float
  title     String
  isTest    Boolean  @default(false)
  paymentId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transactions")
}

model Payment {
  id               String   @id @default(uuid())
  userId           String
  sbpPaymentId     String?  @unique
  yokassaPaymentId String?  @unique
  amount           Float
  status           String   @default("pending")
  qrUrl            String?
  sbpUrl           String?
  provider         String   @default("tochka")
  paymentType      String?
  confirmationUrl  String?
  description      String?
  metadata         Json?
  isTest           Boolean  @default(false)
  creditedAt       DateTime?
  refundedAt       DateTime?
  refundAmount     Float?
  refundReason     String?
  createdAt        DateTime @default(now())
  expiresAt        DateTime @default(dbgenerated("NOW() + INTERVAL '30 minutes'"))
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model PaymentMethod {
  id                String   @id @default(uuid())
  userId            String
  yokassaMethodId   String   @unique
  type              String   @default("bank_card")
  title             String
  cardLast4         String?
  cardBrand         String?
  cardExpMonth      Int?
  cardExpYear       Int?
  isDefault         Boolean  @default(false)
  allowAutoCharge   Boolean  @default(true)
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_methods")
}

model YokassaSettings {
  id                      String   @id @default("global")
  mode                    String   @default("test")
  testSubscriptionEnabled Boolean  @default(false)
  sbpProvider             String   @default("tochka")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("yokassa_settings")
}

model Device {
  id         String     @id @default(uuid())
  userId     String
  name       String
  os         String
  version    String
  lastIp     String
  isBlocked  Boolean    @default(false)
  lastSeenAt DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vpnTokens  VpnToken[]

  @@index([userId])
  @@map("devices")
}

model PromoCode {
  id             String            @id @default(uuid())
  code           String            @unique
  conditions     Json
  effects        Json
  maxActivations Int?
  createdAt      DateTime          @default(now())
  activations    PromoActivation[]

  @@map("promo_codes")
}

model PromoActivation {
  id          String    @id @default(uuid())
  userId      String
  promoCodeId String
  activatedAt DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promoCodeId])
  @@map("promo_activations")
}

model Withdrawal {
  id          String    @id @default(uuid())
  userId      String
  amount      Float
  target      String
  bank        String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("withdrawals")
}

model AppRelease {
  id            String   @id @default(uuid())
  platform      String
  version       String
  changelog     String
  downloadUrl   String
  fileSizeMb    Float
  downloadCount Int      @default(0)
  isLatest      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("app_releases")
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  message   String
  reply     String?
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("support_tickets")
}

model VpnServer {
  id                  String   @id @default(uuid())
  ip                  String
  port                Int
  status              String   @default("offline")
  currentLoad         Int      @default(0)
  lastSeenAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  serverType          String
  supportedProtocols  String[]
  location            String   @default("Unknown, UN")
  connectLinkTemplate String?

  @@unique([ip, port])
  @@map("vpn_servers")
}

model VpnToken {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("vpn_tokens")
}

model ai_conversations {
  id               String             @id
  userId           String
  title            String
  model            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  users            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ai_files         ai_files[]
  ai_messages      ai_messages[]
  ai_usage_entries ai_usage_entries[]

  @@index([userId, updatedAt])
}

model ai_files {
  id               String            @id
  userId           String
  conversationId   String?
  messageId        String?
  fileName         String
  mimeType         String
  size             Int
  blobUrl          String
  kind             String            @default("upload")
  createdAt        DateTime          @default(now())
  ai_conversations ai_conversations? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  ai_messages      ai_messages?      @relation(fields: [messageId], references: [id])
  users            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ai_messages {
  id               String             @id
  conversationId   String
  role             String
  content          String
  reasoning        String?
  attachments      Json?
  artifacts        Json?
  toolEvents       Json?
  model            String?
  inputTokens      Int                @default(0)
  outputTokens     Int                @default(0)
  totalTokens      Int                @default(0)
  costUsd          Float              @default(0)
  createdAt        DateTime           @default(now())
  ai_files         ai_files[]
  ai_conversations ai_conversations   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  ai_usage_entries ai_usage_entries[]

  @@index([conversationId, createdAt])
}

model ai_settings {
  id                   String   @id @default("global")
  openRouterApiKey     String?
  defaultModel         String   @default("qwen3.5:0.8b")
  localModel           String   @default("qwen3.5:0.8b")
  localBaseUrl         String   @default("http://ollama:11434")
  freeMonthlyTokens    Int      @default(500000)
  aiPlanMonthlyTokens  Int      @default(10000000)
  maxPlanMonthlyTokens Int      @default(25000000)
  aiPlanPrice          Float    @default(490)
  maxPlanPrice         Float    @default(890)
  comboPlanPrice       Float    @default(1190)
  tokenPackSize        Int      @default(5000000)
  tokenPackPrice       Float    @default(290)
  systemPrompt         String?
  maxContextMessages   Int      @default(14)
  enableReasoning      Boolean  @default(true)
  hideAiMenuForAll     Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime
}

model ai_subscriptions {
  id                String   @id
  userId            String   @unique
  tier              String
  title             String
  activeUntil       DateTime
  monthlyTokenLimit Int
  monthlyTokensUsed Int      @default(0)
  periodStartsAt    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  users             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ai_usage_entries {
  id               String            @id
  userId           String
  conversationId   String?
  messageId        String?
  provider         String
  model            String
  inputTokens      Int               @default(0)
  outputTokens     Int               @default(0)
  totalTokens      Int               @default(0)
  costUsd          Float             @default(0)
  createdAt        DateTime          @default(now())
  ai_conversations ai_conversations? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  ai_messages      ai_messages?      @relation(fields: [messageId], references: [id])
  users            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model finance_settings {
  id               String   @id @default("global")
  taxRate          Float    @default(0)
  acquiringFeeRate Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model finance_withdrawals {
  id             String   @id
  title          String
  note           String?
  amount         Float
  withdrawalDate DateTime
  createdAt      DateTime @default(now())
  createdById    String?
  users          User?    @relation(fields: [createdById], references: [id])

  @@index([withdrawalDate])
}

model telegram_mailings {
  id              String    @id
  title           String
  message         String
  buttonText      String?
  buttonUrl       String?
  targetType      String
  selectedUserIds String[]  @default([])
  status          String    @default("scheduled")
  scheduledAt     DateTime
  processingAt    DateTime?
  sentAt          DateTime?
  targetCount     Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  createdById     String?
  users           User?     @relation(fields: [createdById], references: [id])

  @@index([createdById, createdAt])
  @@index([status, scheduledAt])
}
